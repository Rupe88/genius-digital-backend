# Server Configuration
NODE_ENV=development
PORT=8000
# Supports multiple origins (web + mobile). Add your production frontend URL.
# Example: CORS_ORIGINS=http://localhost:3000,https://vaastulms.vercel.app,capacitor://localhost,ionic://localhost
CORS_ORIGINS=http://localhost:3000,https://vaastulms.vercel.app,capacitor://localhost,ionic://localhost
# Database
# MySQL (old):
# DATABASE_URL="mysql://lms_user:root@localhost:3306/lms_db"
# PostgreSQL (Supabase):
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"
# Replace [project-ref] with your Supabase project reference. DIRECT_URL is required for Prisma migrations (direct connection; get it from Supabase Dashboard → Settings → Database → Connection string → Direct).

# JWT Secrets
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=7d

# Email - Required for OTP. Use ONE of these:
# Option A: Resend (recommended - reliable, no firewall issues)
# Sign up at resend.com, verify your domain, get API key
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Option B: SMTP (Gmail, etc.)
# For Gmail: Enable 2FA, then create App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password_16_chars

# Application
APP_NAME=LMS Platform
FRONTEND_URL=http://localhost:3000

# Admin Seed (Optional - for initial admin user creation)
ADMIN_EMAIL=admin@lms.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Admin User


# Cloudinary (File Upload - Images, Videos, Documents)
CLOUDINARY_CLOUD_NAME=dtrfe6xfl
CLOUDINARY_API_KEY=928613325392212
CLOUDINARY_API_SECRET=b_LsYqK857F0xPxp43RrGJGcA6g%



# Upload size limits (MB). Optional; defaults: image 10, video 3072 (3GB), document 50.
# UPLOAD_VIDEO_TIMEOUT_MS=600000
# UPLOAD_VIDEO_MAX_MB=3072
# UPLOAD_IMAGE_MAX_MB=10
# UPLOAD_DOCUMENT_MAX_MB=50

# Video Optimization (FFmpeg) - Optional
# Enable/disable video optimization during upload (default: enabled)
# Set to 'false' to disable video optimization
# VIDEO_OPTIMIZATION_ENABLED=true
# Optimization timeout in milliseconds (default: 300000 = 5 minutes)
# VIDEO_OPTIMIZATION_TIMEOUT_MS=300000

# Sparrow SMS (Nepal) - when set, OTP is sent via SMS. BOTH token and sender ID are required.
# Get from https://web.sparrowsms.com/ → Dashboard → API/Settings
# Sender ID must be NTA-approved (6-11 chars, alphanumeric). Without it you get "Invalid Sender (1008)".
SPARROW_SMS_TOKEN=your_sparrow_token
SPARROW_SMS_FROM=YourBrand

# OTP Rate Limiting - Enable/disable rate limiting for OTP requests
# Set to 'false' to disable rate limiting (useful for development/testing)
# Default: true (rate limiting enabled - max 3 OTP requests per hour per user)
ENABLE_OTP_RATE_LIMIT=true

# Course payments: manual QR (admin uploads QR in Admin → QR payments) + user proof screenshot; admin approves in Payments.

