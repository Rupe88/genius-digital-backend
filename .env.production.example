# Copy to /opt/genius-digital-backend/.env on the droplet (chmod 600). Never commit real values.

NODE_ENV=production
PORT=4000

# Public URLs — required for OAuth and CORS
BACKEND_URL=https://api.geniusdigi.com
FRONTEND_URL=https://your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com,http://localhost:3000

# Supabase Postgres — pooler for app, direct for migrations
DATABASE_URL=
DIRECT_URL=

# JWT — use strong random strings (openssl rand -base64 48)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (Resend or SMTP)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=lms-media
USE_SIGNED_VIDEO_URL=true

# Google OAuth — Authorized redirect URI in Google Console:
# https://api.geniusdigi.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: admin seed, payments, SMS, Zoom, etc. (see src/config/env.js)
# APP_NAME=
# FFMPEG_PATH=/usr/bin/ffmpeg
# VIDEO_OPTIMIZATION_ENABLED=true
