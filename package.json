{
  "name": "lms-backend",
  "version": "1.0.0",
  "description": "Nepal's Most Powerful LMS Platform - Backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "predev": "prisma generate && lsof -ti :4000 | xargs kill -9 2>/dev/null || true",
    "dev": "nodemon src/server.js",
    "prestart": "prisma generate",
    "start": "node src/server.js",
    "prestart:migrate": "prisma generate",
    "start:migrate": "npx prisma migrate deploy && node src/server.js",
    "build": "prisma generate",
    "postbuild": "echo 'Build completed successfully'",
    "test": "node test-api.js",
    "test:api": "node test-api.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:db-push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "db:add-upcoming-events-enum": "node scripts/add-upcoming-events-enum.js",
    "db:backup": "node scripts/backup-database.js",
    "lint": "echo 'No linting configured yet'",
    "docker:build": "docker build -t vaastu-lms-backend .",
    "docker:run": "docker run -p 4000:4000 vaastu-lms-backend"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "lms",
    "education",
    "api",
    "nodejs",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@prisma/client": "^5.7.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-useragent": "^2.0.2",
    "express-validator": "^7.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.7",
    "razorpay": "^2.9.2",
    "resend": "^2.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^5.7.1"
  }
}
